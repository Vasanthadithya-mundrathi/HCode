{
  "name": "hcode-tools",
  "displayName": "HCode Security Tools",
  "description": "Security tool runner: nmap, sqlmap, ffuf, gobuster, hydra, hashcat, subfinder, amass, httpx, nikto, and more — with preset argument templates.",
  "version": "1.0.0",
  "publisher": "hcode",
  "license": "MIT",
  "engines": { "vscode": "*" },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onView:hcode.tools.list",
    "onCommand:hcode.welcome.openGettingStarted",
    "onCommand:hcode.tools.run"
  ],
  "main": "./out/extension",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hcode",
          "title": "HCode",
          "icon": "media/hcode-sidebar.svg"
        }
      ]
    },
    "views": {
      "hcode": [
        {
          "id": "hcode.tools.list",
          "name": "Tools",
          "icon": "$(tools)",
          "contextualTitle": "Security Tools"
        }
      ]
    },
    "commands": [
      {
        "command": "hcode.tools.run",
        "title": "Run Tool",
        "icon": "$(play)",
        "category": "HCode Tools"
      },
      {
        "command": "hcode.tools.refresh",
        "title": "Refresh Tool Availability",
        "icon": "$(refresh)",
        "category": "HCode Tools"
      },
      {
        "command": "hcode.tools.install",
        "title": "Install Tool (One Click)",
        "icon": "$(package)",
        "category": "HCode Tools"
      },
      {
        "command": "hcode.tools.checkAll",
        "title": "Check All Tools",
        "icon": "$(checklist)",
        "category": "HCode Tools"
      },
      {
        "command": "hcode.welcome.openGettingStarted",
        "title": "Open HCode Getting Started",
        "icon": "$(book)",
        "category": "HCode"
      },
      {
        "command": "hcode.welcome.openWalkthrough",
        "title": "Open HCode Walkthrough",
        "icon": "$(compass)",
        "category": "HCode"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hcode.tools.refresh",
          "when": "view == hcode.tools.list",
          "group": "navigation@1"
        },
        {
          "command": "hcode.tools.run",
          "when": "view == hcode.tools.list",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "hcode.tools.run",
          "when": "viewItem == hcode.tool.installed",
          "group": "inline@1"
        },
        {
          "command": "hcode.tools.install",
          "when": "viewItem == hcode.tool.missing",
          "group": "inline@1"
        }
      ],
      "commandPalette": [
        { "command": "hcode.tools.run" },
        { "command": "hcode.tools.checkAll" },
        { "command": "hcode.welcome.openGettingStarted" },
        { "command": "hcode.welcome.openWalkthrough" }
      ]
    },
    "walkthroughs": [
      {
        "id": "hcode.gettingStarted",
        "title": "HCode Getting Started",
        "description": "Set up HCode workflows for tools, devices, and ACE orchestration.",
        "steps": [
          {
            "id": "hcode.gettingStarted.tools",
            "title": "Run Your First Security Tool",
            "description": "Start from the tool runner and execute your first command.",
            "media": {
              "image": "media/hcode-sidebar.svg",
              "altText": "HCode Tools"
            },
            "completionEvents": [
              "onCommand:hcode.tools.run"
            ]
          },
          {
            "id": "hcode.gettingStarted.devices",
            "title": "Add a Remote Device",
            "description": "Configure an SSH device with the quick setup wizard.",
            "media": {
              "image": "media/hcode-sidebar.svg",
              "altText": "HCode Devices"
            },
            "completionEvents": [
              "onCommand:hcode.devices.quickSetup"
            ]
          },
          {
            "id": "hcode.gettingStarted.ace",
            "title": "Open ACE Dashboard",
            "description": "Launch ACE to configure provider routing and run objectives.",
            "media": {
              "image": "media/hcode-sidebar.svg",
              "altText": "HCode ACE"
            },
            "completionEvents": [
              "onCommand:hcode.ace.openDashboard"
            ]
          },
          {
            "id": "hcode.gettingStarted.docs",
            "title": "Read the Full Setup Guide",
            "description": "Open detailed onboarding notes and runbook links.",
            "media": {
              "image": "media/hcode-sidebar.svg",
              "altText": "HCode Docs"
            },
            "completionEvents": [
              "onCommand:hcode.welcome.openGettingStarted"
            ]
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "hcode.tools.list",
        "contents": "HCode security workflows start here.\n\n[Open HCode Walkthrough](command:hcode.welcome.openWalkthrough)\n[Run a Tool](command:hcode.tools.run)\n[Open Getting Started](command:hcode.welcome.openGettingStarted)\n[Quick Setup Device](command:hcode.devices.quickSetup)"
      }
    ],
    "keybindings": [
      {
        "command": "hcode.tools.run",
        "key": "cmd+alt+r",
        "mac": "cmd+alt+r",
        "linux": "ctrl+alt+r",
        "when": "!terminalFocus"
      },
      {
        "command": "hcode.welcome.openGettingStarted",
        "key": "cmd+alt+h",
        "mac": "cmd+alt+h",
        "linux": "ctrl+alt+h",
        "when": "!terminalFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "*",
    "@types/node": "*",
    "@types/vscode": "*"
  }
}
