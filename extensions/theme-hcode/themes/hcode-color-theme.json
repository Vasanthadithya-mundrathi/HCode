  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#1e6e1e", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#39ff14" }
    },
    {
      "name": "String escape",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#00e676" }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": { "foreground": "#ffbf00" }
    },
    {
      "name": "Boolean / null / undefined",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#ff6600" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#00bfff", "fontStyle": "bold" }
    },
    {
      "name": "Operator",
      "scope": "keyword.operator",
      "settings": { "foreground": "#00e5ff" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#c8ffc8" }
    },
    {
      "name": "Variable - special / this / self",
      "scope": ["variable.language", "variable.language.this", "variable.language.self"],
      "settings": { "foreground": "#00ff41", "fontStyle": "bold" }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#00e5ff" }
    },
    {
      "name": "Class / type name",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": { "foreground": "#00ff41", "fontStyle": "bold" }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": { "foreground": "#00e676" }
    },
    {
      "name": "Parameter",
      "scope": "variable.parameter",
      "settings": { "foreground": "#a8e8a8" }
    },
    {
      "name": "Property / attribute",
      "scope": ["variable.other.property", "support.variable.property", "entity.other.attribute-name"],
      "settings": { "foreground": "#80d880" }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.other", "variable.other.constant"],
      "settings": { "foreground": "#ffbf00" }
    },
    {
      "name": "Import / module",
      "scope": ["keyword.control.import", "keyword.control.from", "support.module"],
      "settings": { "foreground": "#00bfff" }
    },
    {
      "name": "Tag name",
      "scope": "entity.name.tag",
      "settings": { "foreground": "#00ff41" }
    },
    {
      "name": "Tag attribute",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#80d880" }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation",
      "settings": { "foreground": "#2a8a2a" }
    },
    {
      "name": "Decorator / annotation",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#ff6600" }
    },
    {
      "name": "Invalid / error token",
      "scope": "invalid",
      "settings": { "foreground": "#ff003c", "fontStyle": "underline" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp", "constant.regexp"],
      "settings": { "foreground": "#cc00ff" }
    },
    {
      "name": "Shell variable",
      "scope": "variable.other.readwrite.shell",
      "settings": { "foreground": "#00ff41" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#00ff41", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#c8ffc8", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#80c880", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": "markup.inline.raw",
      "settings": { "foreground": "#39ff14" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#00bfff" }
    },
    {
      "name": "CSS property",
      "scope": "support.type.property-name.css",
      "settings": { "foreground": "#00bfff" }
    },
    {
      "name": "CSS value",
      "scope": "support.constant.property-value.css",
      "settings": { "foreground": "#39ff14" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#c8ffc8",
    "variable.readonly": "#ffbf00",
    "parameter": "#a8e8a8",
    "property": "#80d880",
    "function": "#00e5ff",
    "method": "#00e5ff",
    "class": { "foreground": "#00ff41", "bold": true },
    "interface": { "foreground": "#00e676", "italic": true },
    "enum": "#ffbf00",
    "enumMember": "#ffd700",
    "type": "#00e676",
    "namespace": "#2a9a2a",
    "keyword": { "foreground": "#00bfff", "bold": true },
    "string": "#39ff14",
    "number": "#ffbf00",
    "regexp": "#cc00ff",
    "decorator": "#ff6600",
    "macro": "#ff6600",
    "comment": { "foreground": "#1e6e1e", "italic": true }
  }
}
