{
  "name": "hcode-ace",
  "displayName": "HCode ACE",
  "description": "ACE is HCode's unified autonomous control plane for provider routing, persona selection, protocol bridges, and security skill packs.",
  "version": "1.0.0",
  "publisher": "hcode",
  "license": "MIT",
  "engines": { "vscode": "*" },
  "categories": ["Other"],
  "main": "./out/extension",
  "extensionDependencies": [
    "hcode.hcode-mcp-server",
    "hcode.hcode-skills",
    "hcode.hcode-tools"
  ],
  "activationEvents": [
    "onView:hcode.ace.panel",
    "onCommand:hcode.ace.openDashboard",
    "onCommand:hcode.ace.configureProviderKey",
    "onCommand:hcode.ace.clearProviderKey",
    "onCommand:hcode.ace.openModelManager",
    "onCommand:hcode.ace.runPrompt",
    "onCommand:hcode.ace.testProviderConnection",
    "onCommand:hcode.ace.runObjective",
    "onCommand:hcode.ace.copyMcpUrl",
    "onCommand:hcode.ace.copyAcpSpec",
    "onCommand:hcode.ace.showPersona",
    "onCommand:hcode.ace.openSettings",
    "onCommand:hcode.ace.openExtensions",
    "onCommand:hcode.ace.openTools",
    "onCommand:hcode.ace.startMcpBridge",
    "onCommand:hcode.ace.stopMcpBridge",
    "onCommand:hcode.capabilities.list"
  ],
  "contributes": {
    "views": {
      "hcode": [
        {
          "id": "hcode.ace.panel",
          "name": "ACE",
          "icon": "media/ace-icon.svg",
          "contextualTitle": "ACE Control Plane"
        }
      ]
    },
    "commands": [
      {
        "command": "hcode.ace.openDashboard",
        "title": "Open ACE Dashboard",
        "category": "HCode ACE",
        "icon": "media/ace-icon.svg"
      },
      {
        "command": "hcode.ace.configureProviderKey",
        "title": "Configure Provider API Key",
        "category": "HCode ACE",
        "icon": "$(key)"
      },
      {
        "command": "hcode.ace.openModelManager",
        "title": "Open Model Manager",
        "category": "HCode ACE",
        "icon": "$(server-process)"
      },
      {
        "command": "hcode.ace.clearProviderKey",
        "title": "Clear Provider API Key",
        "category": "HCode ACE",
        "icon": "$(trash)"
      },
      {
        "command": "hcode.ace.runPrompt",
        "title": "Run ACE Prompt",
        "category": "HCode ACE",
        "icon": "$(send)"
      },
      {
        "command": "hcode.ace.testProviderConnection",
        "title": "Test Provider Connection",
        "category": "HCode ACE",
        "icon": "$(pulse)"
      },
      {
        "command": "hcode.ace.runObjective",
        "title": "Run ACE Objective",
        "category": "HCode ACE",
        "icon": "$(run-all)"
      },
      {
        "command": "hcode.ace.copyMcpUrl",
        "title": "Copy MCP URL",
        "category": "HCode ACE",
        "icon": "$(broadcast)"
      },
      {
        "command": "hcode.ace.copyAcpSpec",
        "title": "Copy ACP Beta Spec",
        "category": "HCode ACE",
        "icon": "$(hubot)"
      },
      {
        "command": "hcode.ace.showPersona",
        "title": "Show ACE Persona",
        "category": "HCode ACE",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "hcode.ace.openTools",
        "title": "Open HCode Tools",
        "category": "HCode ACE",
        "icon": "$(tools)"
      },
      {
        "command": "hcode.ace.openSettings",
        "title": "Open ACE Settings",
        "category": "HCode ACE",
        "icon": "$(settings-gear)"
      },
      {
        "command": "hcode.ace.openExtensions",
        "title": "Open Extensions",
        "category": "HCode ACE",
        "icon": "$(extensions)"
      },
      {
        "command": "hcode.ace.startMcpBridge",
        "title": "Start MCP Bridge",
        "category": "HCode ACE",
        "icon": "$(play)"
      },
      {
        "command": "hcode.ace.stopMcpBridge",
        "title": "Stop MCP Bridge",
        "category": "HCode ACE",
        "icon": "$(debug-stop)"
      },
      {
        "command": "hcode.capabilities.list",
        "title": "List HCode Capabilities",
        "category": "HCode ACE",
        "icon": "$(symbol-method)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hcode.ace.configureProviderKey",
          "when": "view == hcode.ace.panel",
          "group": "navigation@1"
        },
        {
          "command": "hcode.ace.copyMcpUrl",
          "when": "view == hcode.ace.panel",
          "group": "navigation@2"
        },
        {
          "command": "hcode.ace.runPrompt",
          "when": "view == hcode.ace.panel",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        { "command": "hcode.ace.openDashboard" },
        { "command": "hcode.ace.configureProviderKey" },
        { "command": "hcode.ace.openModelManager" },
        { "command": "hcode.ace.testProviderConnection" },
        { "command": "hcode.ace.copyAcpSpec" },
        { "command": "hcode.ace.runPrompt" },
        { "command": "hcode.ace.runObjective" },
        { "command": "hcode.ace.showPersona" },
        { "command": "hcode.ace.openTools" },
        { "command": "hcode.ace.openSettings" },
        { "command": "hcode.ace.openExtensions" },
        { "command": "hcode.capabilities.list" }
      ]
    },
    "keybindings": [
      {
        "command": "hcode.ace.openDashboard",
        "key": "cmd+alt+a",
        "mac": "cmd+alt+a",
        "linux": "ctrl+alt+a",
        "when": "!terminalFocus"
      },
      {
        "command": "hcode.ace.runPrompt",
        "key": "cmd+alt+p",
        "mac": "cmd+alt+p",
        "linux": "ctrl+alt+p",
        "when": "!terminalFocus"
      },
      {
        "command": "hcode.ace.testProviderConnection",
        "key": "cmd+alt+t",
        "mac": "cmd+alt+t",
        "linux": "ctrl+alt+t",
        "when": "!terminalFocus"
      },
      {
        "command": "hcode.ace.runObjective",
        "key": "cmd+alt+o",
        "mac": "cmd+alt+o",
        "linux": "ctrl+alt+o",
        "when": "!terminalFocus"
      }
    },
    "configuration": {
      "title": "HCode ACE",
      "properties": {
        "hcode.ace.activeProvider": {
          "type": "string",
          "default": "openai",
          "enum": ["openai", "anthropic", "google-gemini", "openrouter", "ollama", "azure-openai", "qwen-compatible", "gemini-cli", "qwen-cli", "opencode-cli"],
          "description": "The default ACE model provider used by the control plane. API keys are stored in VS Code secret storage, not in settings."
        },
        "hcode.ace.defaultPersona": {
          "type": "string",
          "default": "ace-vanguard",
          "enum": ["ace-vanguard", "ace-operator", "ace-cartographer"],
          "description": "The default ACE persona. Personas control system framing, response posture, and operating style."
        },
        "hcode.ace.enableACPBeta": {
          "type": "boolean",
          "default": true,
          "description": "Enable the ACE Control Plane beta scaffolding for short-lived task workers and deterministic validation."
        },
        "hcode.ace.enableMCPBridge": {
          "type": "boolean",
          "default": true,
          "description": "Display and use the local MCP bridge exposed by HCode MCP Server."
        },
        "hcode.ace.activeModel": {
          "type": "string",
          "default": "",
          "description": "Optional override for the active provider model. Leave empty to use provider-specific defaults."
        },
        "hcode.ace.providerEndpointOverrides": {
          "type": "object",
          "default": {},
          "description": "Optional provider endpoint overrides keyed by provider id. Example: { \"openai\": \"https://api.openai.com\" }."
        },
        "hcode.ace.providerModelOverrides": {
          "type": "object",
          "default": {},
          "description": "Optional provider model overrides keyed by provider id. Example: { \"ollama\": \"llama3.2\" }."
        },
        "hcode.ace.cliAdapters": {
          "type": "object",
          "default": {
            "gemini-cli": {
              "command": "gemini",
              "args": ["--prompt", "{prompt}"],
              "passViaStdin": false
            },
            "qwen-cli": {
              "command": "qwen",
              "args": ["--prompt", "{prompt}"],
              "passViaStdin": false
            },
            "opencode-cli": {
              "command": "opencode",
              "args": ["--prompt", "{prompt}"],
              "passViaStdin": false
            }
          },
          "description": "CLI adapter configuration keyed by provider id (gemini-cli, qwen-cli, opencode-cli). Use {prompt} and {systemPrompt} placeholders in args."
        },
        "hcode.ace.azureOpenAIDeployment": {
          "type": "string",
          "default": "",
          "description": "Azure OpenAI deployment name used when the active provider is azure-openai."
        },
        "hcode.ace.azureOpenAIApiVersion": {
          "type": "string",
          "default": "2024-10-21",
          "description": "Azure OpenAI API version used for ACE runtime requests."
        },
        "hcode.ace.requestTimeoutMs": {
          "type": "number",
          "default": 45000,
          "minimum": 5000,
          "description": "Timeout for ACE provider requests in milliseconds."
        },
        "hcode.ace.kaliHost": {
          "type": "string",
          "default": "192.168.64.6",
          "description": "Kali host used for ACE integration reachability status checks."
        },
        "hcode.ace.kaliSshPort": {
          "type": "number",
          "default": 22,
          "minimum": 1,
          "maximum": 65535,
          "description": "SSH port used for Kali reachability status checks in ACE dashboard."
        },
        "hcode.ace.acpMaxWorkers": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 5,
          "description": "Maximum number of ACP worker tasks dispatched for a single objective."
        },
        "hcode.ace.acpWorkerTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 10000,
          "description": "Timeout in milliseconds for a single ACP objective execution."
        },
        "hcode.ace.xbowInspiredLoop": {
          "type": "boolean",
          "default": true,
          "description": "Display the XBow-inspired short-lived worker loop and deterministic validation pattern in the ACE dashboard."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "*",
    "@types/node": "*",
    "@types/vscode": "*"
  }
}
